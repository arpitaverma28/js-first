//What are Falsy Values? : Falsy values are values that become false when converted to Boolean.
/*
JavaScript has only 7 falsy values.

Value	              Meaning
false	            Boolean false
0	                number zero
-0              	negative zero
0n                  BigInt
""              	empty string
null            	no value
undefined	       variable not defined
NaN                not a number
*/

//🔹 Opposite of Falsy → Truthy : Everything that is not falsy is truthy.

console.log(false==0); //true
console.log(false===0); //false



//What is Nullish Coalescing? : The Nullish Coalescing Operator (??) is used to provide a default value when a variable is null or undefined.
//value ?? defaultValue
//If value is null or undefined → use defaultValue , Otherwise → use value


let a = "Hello";
console.log(a ?? "hi"); //hello

let b =null;
console.log(b ?? "hi"); //hi

let c =undefined;
console.log(c ?? "Rashi"); //Rashi


